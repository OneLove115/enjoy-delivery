# Veloci consumer API base URL (required)
# For preview deploys, point to your Vercel preview URL or staging instance:
# VELOCIPIZZA_API_URL=https://velocipizza-git-my-branch-veloci-online.vercel.app
VELOCIPIZZA_API_URL=https://www.veloci.online
NEXT_PUBLIC_VP_DOMAIN=https://www.veloci.online

# Session / cookie secret (required, min 32 chars)
SESSION_SECRET=replace-with-a-long-random-string

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# AI features (optional — TTS and chat widget)
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
